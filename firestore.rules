rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Chatbot Leads Collection (Lead Security)
    // Website visitors can submit/update lead info
    // ONLY authenticated admins can READ or DELETE lead records
    match /chatbot_leads/{leadId} {
      allow create, update: if true;
      allow read, delete: if request.auth != null;
    }

    // 2. Public Site CMS Content & Settings
    // Public visitors can read site content (blogs, portfolio, services)
    // ONLY authenticated admins can edit/write content
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
