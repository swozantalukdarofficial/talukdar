rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to all documents by default (public site needs to load CMS content)
    // Allow write/update access only to authenticated users (admin panel users)
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
